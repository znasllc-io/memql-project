# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore
#
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Dependency directories (remove the comment below to include it)
# vendor/

# go.work IS committed here -- this repo is the workspace root and the
# committed manifest is the checked-in baseline bootstrap regenerates at
# stamp time. Only the machine-local sum file stays untracked.
go.work.sum

# env file
.env

# Sibling repo checkouts living inside the workspace root. Each is its own
# git repository (cloned/scaffolded by scripts/bootstrap.sh), never tracked
# by the workspace repo. bootstrap.sh appends the product-specific lines
# (/<product>-bundle/, /<product>-client/) at stamp time.
/memql/
/memql-cockpit/
