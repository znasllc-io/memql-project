# memQL product repo (DSL-first; no Go in the common case).
#
# product.env is COMMITTED, not ignored: it is the product's identity that every
# operational file reads (scripts/init.sh writes it at stamp time). The engine +
# cockpit are cloned as SIBLINGS in the PARENT directory, so they are outside
# this repo and need no ignore entry here.

# Node / client build artifacts (client/ also has its own .gitignore).
node_modules/
dist/

# Env / secrets (never commit real secrets).
.env
.env.local
*.local

# Editor / OS
.DS_Store
.idea/
.vscode/

# Logs
npm-debug.log*

# Go (only if a product later adds a bff plugin module -- memql-project#11).
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out
coverage.*
go.work.sum
