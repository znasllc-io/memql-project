// Workspace manifest for a memQL product constellation. The __PRODUCT__
// token is substituted by scripts/bootstrap.sh at stamp time; bootstrap
// also regenerates the use list from the checkouts that actually exist
// (the client repo is not a Go module and is deliberately absent).
go 1.26.3

use (
	./memql
	./__PRODUCT__-carrier
	./memql-cockpit
)
