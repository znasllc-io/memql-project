# Local override for the __PRODUCT__ client dev server. Copy to .env (gitignored).
#
# The bff front door the browser talks to (the /memql WS bridge + query surface).
# Vite proxies /memql here in dev; the built image relies on the ingress instead.
VITE_MEMQL_HTTP_URL=https://bff.__DOMAIN__

# The identity service base URL (magic-link login + JWKS).
VITE_IDENTITY_BASE_URL=https://identity.__DOMAIN__
