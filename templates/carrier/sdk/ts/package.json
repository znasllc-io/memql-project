{
  "name": "@__PRODUCT_ORG__/__PRODUCT__-sdk",
  "version": "0.1.0",
  "description": "Typed memQL SDK for the __PRODUCT__ web app: the @znasllc-io/memql-sdk-core runtime plus the generated __PRODUCT__ query/mutation/logic surface (core DSL + __PRODUCT__ DSL).",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./voice": {
      "types": "./dist/voice.d.ts",
      "import": "./dist/voice.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@znasllc-io/memql-sdk-core": "^0.4.0"
  },
  "devDependencies": {
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/__PRODUCT_ORG__/__PRODUCT__-carrier.git",
    "directory": "sdk/ts"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  }
}
