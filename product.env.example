# product.env -- the single source of product identity for THIS repo.
#
# scripts/init.sh writes the real product.env from your --product / --product-org
# / --domain / --engine-ref / --registry flags and PRUNES this .example. Every
# operational file (the root + client Makefiles, scripts/*, CI) reads product.env
# and stays byte-identical to the template, so a later `git merge template/main`
# never conflicts on them. Values that a tool genuinely cannot read at runtime
# (a concept namespace in .memql, an ingress hostname, an image name) are the
# only things init.sh stamps into file contents.
#
# Format: KEY=value, one per line, shell-sourceable (no spaces around =).

# Product name -- lowercase slug, ^[a-z][a-z0-9-]*$. Names the DSL namespace,
# the client package, the bundle/client image repositories.
PRODUCT=__PRODUCT__

# GitHub org/user that owns this product repo (and, if you publish one, the SDK
# package scope). Not the engine org -- znasllc-io stays literal everywhere.
PRODUCT_ORG=__PRODUCT_ORG__

# The engine's fixed local domain (mkcert wildcard). The local stack serves
# https://identity.$DOMAIN, https://bff.$DOMAIN, https://app.$DOMAIN. Identity /
# TLS / issuer are engine-owned and fixed at this domain, so leave it at the
# default for local; it is also the staging/prod public-entry placeholder you set
# on the overlays at activation time.
DOMAIN=__DOMAIN__

# Engine ref this product ships against: a git tag/branch of znasllc-io/memql.
# The local stack runs `make -C ../memql up` at this ref; the overlays pin the
# engine node images to it. init.sh DEFAULTS this to "main": no tagged engine
# release yet carries the downstream contract (downstream-stacks.md sinceVersion
# 0.12.0; the latest tag 0.11.2 lacks scripts/k3d/import-image.sh and a
# compatible DSL grammar). Flips back to the latest release tag once >=0.12.0
# ships -- znasllc-io/memql#2510 (release gap), memql-project#14 (flip-back).
ENGINE_REF=__ENGINE_REF__

# Container registry that hosts the product's bundle + client images
# (e.g. ghcr.io/acme-io or acme.azurecr.io). EMPTY = local-only: images build
# and import into k3d by bare name, staging/prod stay unshipped. The local
# overlay works with no registry at all.
REGISTRY=
